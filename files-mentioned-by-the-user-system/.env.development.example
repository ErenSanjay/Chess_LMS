APP_ENV=development
PROJECT_NAME=Chess LMS

POSTGRES_DB=chess_lms
POSTGRES_USER=chess_lms
POSTGRES_PASSWORD=dev-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://chess_lms:dev-password@postgres:5432/chess_lms

REDIS_URL=redis://redis:6379/0

JWT_ISSUER=chess-lms
JWT_AUDIENCE=chess-lms-web
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
JWT_PRIVATE_KEY=dev-only-private-key
JWT_PUBLIC_KEY=dev-only-public-key
PASSWORD_PEPPER=dev-only-password-pepper

CORS_ALLOWED_ORIGINS=http://localhost:3000
COOKIE_DOMAIN=localhost
CSRF_SECRET=dev-only-csrf-secret

EMAIL_PROVIDER=mailpit
EMAIL_FROM=no-reply@chess-lms.local
SMTP_HOST=mailpit
SMTP_PORT=1025

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8000/ws/v1
